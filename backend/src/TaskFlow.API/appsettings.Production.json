{
  /*
   * appsettings.Production.json
   * ════════════════════════════
   * Configuration values for PRODUCTION environment.
   *
   * HOW IT WORKS:
   * ─────────────────────────────────────────────────────────────
   * ASP.NET Core reads config in this order (later overrides earlier):
   *   1. appsettings.json           (base config, in source code)
   *   2. appsettings.Production.json (this file, overrides base)
   *   3. Environment Variables       (overrides files — used in Docker)
   *   4. Azure Key Vault             (optional, for secrets)
   *
   * RULE: Never put secrets in these files!
   *   ❌ "SecretKey": "mysecret123"    ← bad, committed to git
   *   ✅ "SecretKey": ""               ← empty, set via env var
   *
   * In production, secrets come from:
   *   - Docker: -e JWT_SECRET=xxx
   *   - Azure App Service: Application Settings
   *   - GitHub Actions: Secrets → passed as env vars
   */

  // Strict HTTPS requirement in production
  "ASPNETCORE_HTTPS_PORT": 443,

  // Serilog — structured logging (JSON format for Azure Log Analytics)
  "Serilog": {
    "Using":  ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default":    "Information",
      "Override": {
        "Microsoft":                         "Warning",
        "Microsoft.Hosting.Lifetime":        "Information",
        "Microsoft.EntityFrameworkCore":     "Warning",
        "System":                            "Warning"
      }
    },
    "WriteTo": [
      {
        // Console output in JSON format (Azure reads this)
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        // File output with daily rolling (max 7 files, 50MB each)
        "Name": "File",
        "Args": {
          "path":             "/app/logs/taskflow-.log",
          "rollingInterval":  "Day",
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },

  // ── Database ───────────────────────────────────────────────
  // Empty — set via environment variable:
  // ConnectionStrings__DefaultConnection=Server=...
  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  // ── JWT ────────────────────────────────────────────────────
  // SecretKey is EMPTY here — injected via env var
  "JwtSettings": {
    "SecretKey":          "",
    "Issuer":             "TaskFlow",
    "Audience":           "TaskFlowApp",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays":   7
  },

  // ── CORS ───────────────────────────────────────────────────
  // Restrict to production domain only
  "AllowedOrigins": "",   // Set via env: AllowedOrigins=https://taskflow.com

  // ── Swagger ────────────────────────────────────────────────
  // Disable Swagger UI in production (security)
  "SwaggerSettings": {
    "Enabled": false
  },

  // ── SignalR ────────────────────────────────────────────────
  "SignalRSettings": {
    "EnableDetailedErrors": false
    // For multi-server: add Redis backplane
    // "RedisConnectionString": ""
  },

  // ── Health Checks ──────────────────────────────────────────
  "HealthChecks": {
    "Enabled":           true,
    "DatabaseTimeout":   "00:00:05",
    "SignalRCheck":      true
  },

  // ── Rate Limiting ──────────────────────────────────────────
  "RateLimiting": {
    "Enabled":             true,
    "PermitLimit":         100,   // Max 100 requests per window
    "WindowSeconds":       60,    // Per 60-second window
    "QueueLimit":          10,    // Queue 10 extra requests before 429
    "LoginPermitLimit":    10,    // Strict limit for /auth/login (brute force protection)
    "LoginWindowSeconds":  60
  },

  // ── Email (for notifications) ──────────────────────────────
  "EmailSettings": {
    "SmtpHost":     "",    // Set via env: EmailSettings__SmtpHost
    "SmtpPort":     587,
    "EnableSsl":    true,
    "SmtpUser":     "",
    "SmtpPassword": "",
    "FromEmail":    "",
    "FromName":     "TaskFlow"
  }
}
