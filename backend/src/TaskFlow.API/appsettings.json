{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TaskFlowDB;User Id=sa;Password=YourStrong!Password;Encrypt=false;TrustServerCertificate=true;"
  },

  "Jwt": {
    "AccessSecret":  "REPLACE_THIS_WITH_A_RANDOM_64_CHAR_SECRET_IN_PRODUCTION_NEVER_COMMIT",
    "RefreshSecret": "REPLACE_THIS_WITH_A_DIFFERENT_64_CHAR_SECRET_FOR_REFRESH_TOKENS",
    "Issuer":        "taskflow-api",
    "Audience":      "taskflow-client",
    "AccessTokenExpiryMinutes":    15,
    "RefreshTokenExpiryDays":       7,
    "ResetTokenExpiryHours":        1,
    "EmailVerifyTokenExpiryHours": 24
  },

  "Security": {
    "MaxFailedLoginAttempts":    5,
    "LockoutDurationMinutes":   15,
    "MaxActiveRefreshTokens":    5,
    "BcryptWorkFactor":         12,
    "RequireEmailVerification": false
  },

  "Email": {
    "Host":        "smtp.gmail.com",
    "Port":        587,
    "EnableSsl":   true,
    "Username":    "noreply@taskflow.com",
    "Password":    "USE_APP_SPECIFIC_PASSWORD",
    "FromName":    "TaskFlow",
    "FromAddress": "noreply@taskflow.com"
  },

  "Cors": {
    "AllowedOrigins": "http://localhost:3000,http://localhost:5173"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },

  "AllowedHosts": "*"
}
