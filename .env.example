# ════════════════════════════════════════════════════════════════
# .env.example — Environment Variables Template
# ════════════════════════════════════════════════════════════════
#
# IMPORTANT: Copy this file to ".env" and fill in real values.
#   cp .env.example .env
#
# NEVER commit .env to Git! It contains secrets.
# Only commit .env.example (with placeholder values).
#
# WHAT ARE ENVIRONMENT VARIABLES?
# ────────────────────────────────
# Config values injected into containers at runtime.
# Keeps secrets OUT of your code and Docker images.
#
# Think: Your app reads process.env.JWT_SECRET instead of
#        having "mysecret123" hardcoded in the source code.

# ── APPLICATION ───────────────────────────────────────────────
VERSION=1.0.0
ASPNETCORE_ENVIRONMENT=Production

# ── DATABASE ──────────────────────────────────────────────────
# ⚠️  CHANGE THIS — must meet SQL Server complexity requirements:
#     - Min 8 chars, uppercase, lowercase, number, special char
SQL_SA_PASSWORD=TaskFlow@Prod123!ChangeMeNow
SQL_DB_NAME=TaskFlowDB
SQL_PORT=1433

# ── JWT AUTHENTICATION ────────────────────────────────────────
# ⚠️  CHANGE THIS — must be at least 32 characters (256 bits)
#     Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_256_BIT_SECRET_KEY_AT_LEAST_32_CHARS
JWT_ISSUER=TaskFlow
JWT_AUDIENCE=TaskFlowApp
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# ── PORTS ─────────────────────────────────────────────────────
FRONTEND_PORT=80
BACKEND_PORT=5000

# ── CORS ──────────────────────────────────────────────────────
# In production: use your real domain name
ALLOWED_ORIGINS=http://localhost,https://yourdomain.com

# ── EMAIL (for password reset, notifications) ─────────────────
# Use a real SMTP provider: SendGrid, Mailgun, AWS SES
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.YOUR_SENDGRID_API_KEY_HERE
FROM_EMAIL=noreply@taskflow.yourdomain.com

# ── LOGGING ───────────────────────────────────────────────────
# Development: Debug | Staging: Information | Production: Warning
LOG_LEVEL=Information

# ── DOCKER REGISTRY (for CI/CD) ───────────────────────────────
# GitHub Container Registry (ghcr.io) or Docker Hub
REGISTRY=ghcr.io
GITHUB_ORG=your-github-username

# ── AZURE (for cloud deployment) ──────────────────────────────
AZURE_RESOURCE_GROUP=taskflow-rg
AZURE_LOCATION=eastus
AZURE_APP_SERVICE_PLAN=taskflow-plan
AZURE_BACKEND_APP=taskflow-api
AZURE_FRONTEND_APP=taskflow-web
AZURE_ACR_NAME=taskflowacr
AZURE_SQL_SERVER=taskflow-sql-server
